# Streamlit secrets template.
#
# LOCAL:  copy to `.streamlit/secrets.toml` (gitignored) OR just use `.env`.
# CLOUD:  paste these lines into Streamlit Cloud → app → Settings → Secrets.
#
# Only GROQ_KEY_1 is required; 2 and 3 are optional fallbacks if the first is rate-limited.

GROQ_KEY_1 = "gsk_your_key_here"
GROQ_KEY_2 = ""
GROQ_KEY_3 = ""
